NODE_ENV=development
PORT=5001

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/bananthi_mane

JWT_SECRET=change_this_to_a_long_random_secret
CLIENT_URL=http://localhost:5173

# Razorpay (test keys start with rzp_test_)
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Shiprocket (production credentials)
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=your_password

# Email Service (Gmail SMTP — generate App Passwords in Google Workspace)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
